# ── Application ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# ── Pipeline Thresholds ───────────────────────────────────────────────────────
FAKE_THRESHOLD=0.65
REAL_THRESHOLD=0.35

# ── Model Weights ─────────────────────────────────────────────────────────────
# Place trained .pth files in models/weights/
MODEL_DIR=models/weights
TSF_CHECKPOINT=tsf_model.pth
AVS_CHECKPOINT=avs_model.pth
SFA_CHECKPOINT=sfa_model.pth
BIO_CHECKPOINT=bio_model.pth
FUSION_CHECKPOINT=fusion_classifier.pth
